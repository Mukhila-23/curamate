<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Medicine Name -->
        <EditText
            android:layout_marginTop="50dp"
            android:id="@+id/edtMedicineName"
            android:hint="Enter Medicine Name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <!-- Days of the Week -->
        <TextView
            android:text="Select Days:"
            android:textSize="16sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/dayCheckboxLayout"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <CheckBox android:id="@+id/chkSun" android:text="Sunday"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <CheckBox android:id="@+id/chkMon" android:text="Monday"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <CheckBox android:id="@+id/chkTue" android:text="Tuesday"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <CheckBox android:id="@+id/chkWed" android:text="Wednesday"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <CheckBox android:id="@+id/chkThu" android:text="Thursday"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <CheckBox android:id="@+id/chkFri" android:text="Friday"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <CheckBox android:id="@+id/chkSat" android:text="Saturday"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Add Times -->
        <Button
            android:id="@+id/btnSetTime"
            android:text="Add Time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp" />

        <!-- Show added times -->
        <TextView
            android:id="@+id/txtTimes"
            android:text="No times added yet."
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

        <!-- Save Medicine -->
        <Button
            android:id="@+id/btnSaveMedicine"
            android:text="Save Medicine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </LinearLayout>
</ScrollView>
