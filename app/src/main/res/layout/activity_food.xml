<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Generic meal card: Breakfast -->
        <LinearLayout
            android:id="@+id/cardBreakfast"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:background="@android:color/transparent">

            <Button
                android:id="@+id/btnBreakfast"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Breakfast"
                android:textSize="20sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/txtBreakfastTime"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Time: Not set"
                    android:textColor="@color/black"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btnBreakfastSetTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Set Time" />

                <Button
                    android:id="@+id/btnBreakfastCustomize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Customize"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Brunch -->
        <LinearLayout
            android:id="@+id/cardBrunch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnBrunch"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Brunch"
                android:textSize="20sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/txtBrunchTime"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Time: Not set"
                    android:textColor="@color/black"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btnBrunchSetTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Set Time" />

                <Button
                    android:id="@+id/btnBrunchCustomize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Customize"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Lunch -->
        <LinearLayout
            android:id="@+id/cardLunch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnLunch"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Lunch"
                android:textSize="20sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/txtLunchTime"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:text="Time: Not set"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btnLunchSetTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Set Time" />

                <Button
                    android:id="@+id/btnLunchCustomize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Customize"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Snack -->
        <LinearLayout
            android:id="@+id/cardSnack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnSnack"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Snack"
                android:textSize="20sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/txtSnackTime"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:text="Time: Not set"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btnSnackSetTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Set Time" />

                <Button
                    android:id="@+id/btnSnackCustomize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Customize"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Dinner -->
        <LinearLayout
            android:id="@+id/cardDinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnDinner"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Dinner"
                android:textSize="20sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/txtDinnerTime"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Time: Not set"
                    android:textColor="@color/black"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btnDinnerSetTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Set Time" />

                <Button
                    android:id="@+id/btnDinnerCustomize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Customize"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
