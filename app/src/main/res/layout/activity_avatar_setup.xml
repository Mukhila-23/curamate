<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    >
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center">

        <TextView
            android:layout_marginTop="50dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose an avatar:"
            android:textColor="@color/white"
            android:textSize="16sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <ImageButton
                android:id="@+id/imgAvatar1"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/avatar1"
                android:background="@null"
                android:scaleType="centerCrop"/>

            <ImageButton
                android:id="@+id/imgAvatar2"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/avatar2"
                android:background="@null"
                android:scaleType="centerCrop"
                android:layout_marginStart="12dp"/>

            <ImageButton
                android:id="@+id/imgAvatar3"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/avatar3"
                android:background="@null"
                android:scaleType="centerCrop"
                android:layout_marginStart="12dp"/>
        </LinearLayout>

        <TextView
            android:layout_marginTop="18dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Avatar name:"
            android:textColor="@color/white"/>

        <EditText
            android:id="@+id/editAvatarName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g., CareBot" />

        <TextView
            android:layout_marginTop="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="What should the avatar call you?"
            android:textColor="@color/white"/>

        <EditText
            android:id="@+id/editUserName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g., Mukhila" />
        <TextView
            android:id="@+id/tvInstructions"
            android:layout_marginTop="5dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Please follow these instructions before continuing:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"
            android:gravity="start"/>

        <CheckBox
            android:id="@+id/cbTime24"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Set time to 24-hour format"
            android:layout_marginBottom="8dp"/>

        <CheckBox
            android:id="@+id/cbBackground"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2. Allow background activity"
            android:layout_marginBottom="8dp"/>

        <CheckBox
            android:id="@+id/cbBattery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="3. Disable battery optimization for CuraMate"
            android:layout_marginBottom="24dp"/>


        <Button
            android:id="@+id/btnSaveAvatar"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save and Continue"/>
    </LinearLayout>
</ScrollView>
